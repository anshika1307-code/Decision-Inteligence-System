# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=false

# LLM Providers
OPENAI_API_KEY=sk-your-openai-api-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here
COHERE_API_KEY=your-cohere-api-key-here

# Vector Database (Qdrant)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=
QDRANT_COLLECTION=decision_intelligence
QDRANT_HTTPS=false

# Cache (Redis)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CACHE_TTL=86400

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/decision_intelligence
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Observability
LANGSMITH_API_KEY=your-langsmith-api-key-here
LANGSMITH_PROJECT=decision-intelligence
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LOG_LEVEL=INFO
LOG_FORMAT=json

# Security
JWT_SECRET_KEY=your-secret-key-here-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Rate Limiting
RATE_LIMIT_PER_USER=100
RATE_LIMIT_WINDOW_HOURS=1
RATE_LIMIT_GLOBAL=1000

# Retrieval Configuration
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSION=3072
VECTOR_TOP_K=20
BM25_TOP_K=20
RERANK_TOP_N=10
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Agent Configuration
CLASSIFIER_MODEL=gpt-4o-mini
RESEARCH_MODEL=gpt-4o
RISK_MODEL=gpt-4o
FINANCIAL_MODEL=gpt-4o
FACT_CHECK_MODEL=claude-3-5-sonnet-20241022
SUMMARY_MODEL=gpt-4o

# Evaluation
RAGAS_ENABLED=true
RAGAS_SAMPLE_RATE=0.1

# Cost Tracking
COST_TRACKING_ENABLED=true
COST_ALERT_THRESHOLD_USD=10.0

# Performance
MAX_CONCURRENT_AGENTS=5
AGENT_TIMEOUT_SECONDS=60
RETRIEVAL_TIMEOUT_SECONDS=10
