# This file contains environment variables for configuring the application.
# It serves as a template for your .env file.
# Copy this file to .env and fill in the values.

# ==============================================
# REQUIRED: Core Configuration
# ==============================================

# OpenAI API Key (REQUIRED - Get from https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-your-openai-api-key-here

# ==============================================
# OPTIONAL: Additional LLM Providers
# ==============================================

# Anthropic API Key (Optional - for Claude models)
ANTHROPIC_API_KEY=

# Cohere API Key (Optional - for Rerank API, defaults to local Cross-Encoder)
COHERE_API_KEY=

# ==============================================
# API Configuration
# ==============================================

# Host for the API server
API_HOST=0.0.0.0
# Port for the API server
API_PORT=8000
# Number of worker processes for the API server (e.g., 2x number of CPU cores)
API_WORKERS=4
# Enable auto-reloading of the API server on code changes (for development)
API_RELOAD=false

# ==============================================
# Vector Database (Qdrant)
# ==============================================

# Host for the Qdrant vector database
QDRANT_HOST=localhost
# Port for the Qdrant vector database
QDRANT_PORT=6333
# API Key for Qdrant (if authentication is enabled)
QDRANT_API_KEY=
# Name of the collection to use in Qdrant
QDRANT_COLLECTION=decision_intelligence
# Use HTTPS for Qdrant connection
QDRANT_HTTPS=false

# ==============================================
# Cache (Redis)
# ==============================================

# Host for the Redis cache
REDIS_HOST=localhost
# Port for the Redis cache
REDIS_PORT=6379
# Password for Redis (if authentication is enabled)
REDIS_PASSWORD=
# Database number to use in Redis
REDIS_DB=0
# Time-to-live for cached items in seconds (e.g., 86400 seconds = 24 hours)
REDIS_CACHE_TTL=86400

# ==============================================
# Database (PostgreSQL)
# ==============================================

# Connection URL for the PostgreSQL database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/decision_intelligence
# Maximum number of connections in the database pool
DATABASE_POOL_SIZE=10
# Maximum number of connections that can be opened beyond the pool size
DATABASE_MAX_OVERFLOW=20

# ==============================================
# Model Selection (Cost-Optimized Defaults)
# ==============================================

# Default LLM for classifying user queries
CLASSIFIER_MODEL=gpt-4o-mini
# Default LLM for conducting research tasks
RESEARCH_MODEL=gpt-4o-mini
# Default LLM for assessing risks
RISK_MODEL=gpt-4o-mini
# Default LLM for financial analysis
FINANCIAL_MODEL=gpt-4o-mini
# Default LLM for fact-checking information
FACT_CHECK_MODEL=gpt-4o-mini
# Default LLM for summarizing content
SUMMARY_MODEL=gpt-4o-mini
# Default embedding model for converting text to vectors
EMBEDDING_MODEL=text-embedding-3-small
# Dimension of the embeddings generated by EMBEDDING_MODEL
EMBEDDING_DIMENSION=1536

# ==============================================
# Observability (Optional)
# ==============================================

# LangSmith API Key (Optional - for debugging agent traces and monitoring)
LANGSMITH_API_KEY=
# LangSmith project name to log traces to
LANGSMITH_PROJECT=decision-intelligence
# LangSmith endpoint (default is https://api.smith.langchain.com)
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# Logging level (e.g., INFO, DEBUG, WARNING, ERROR)
LOG_LEVEL=INFO
# Logging format (e.g., json, console)
LOG_FORMAT=json

# ==============================================
# Security
# ==============================================

# Secret key for signing JWT tokens (REQUIRED - CHANGE IN PRODUCTION)
JWT_SECRET_KEY=your-secret-key-here-change-in-production
# Algorithm used for JWT signing (e.g., HS256)
JWT_ALGORITHM=HS256
# Expiration time for JWT tokens in hours
JWT_EXPIRATION_HOURS=24

# ==============================================
# Rate Limiting
# ==============================================

# Maximum number of requests allowed per user within the window
RATE_LIMIT_PER_USER=100
# Time window for user rate limiting in hours
RATE_LIMIT_WINDOW_HOURS=1
# Global maximum number of requests allowed across all users within the window
RATE_LIMIT_GLOBAL=1000

# ==============================================
# Retrieval Configuration
# ==============================================

# Number of top vector search results to retrieve
VECTOR_TOP_K=20
# Number of top BM25 search results to retrieve
BM25_TOP_K=20
# Number of top results to pass to the reranker
RERANK_TOP_N=10
# Size of text chunks for embedding and retrieval
CHUNK_SIZE=1000
# Overlap between text chunks
CHUNK_OVERLAP=200

# Agent Configuration
CLASSIFIER_MODEL=gpt-4o-mini
RESEARCH_MODEL=gpt-4o
RISK_MODEL=gpt-4o
FINANCIAL_MODEL=gpt-4o
FACT_CHECK_MODEL=claude-3-5-sonnet-20241022
SUMMARY_MODEL=gpt-4o

# Evaluation
RAGAS_ENABLED=true
RAGAS_SAMPLE_RATE=0.1

# Cost Tracking
COST_TRACKING_ENABLED=true
COST_ALERT_THRESHOLD_USD=10.0

# Performance
MAX_CONCURRENT_AGENTS=5
AGENT_TIMEOUT_SECONDS=60
RETRIEVAL_TIMEOUT_SECONDS=10
